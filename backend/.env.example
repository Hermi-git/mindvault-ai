ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://mindvault:mindvault@postgres:5432/mindvault
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ISSUER=mindvault-ai
JWT_AUDIENCE=mindvault-clients
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
MFA_ATTEMPT_TTL_SECONDS=300
INVITATION_TTL_SECONDS=172800
JWT_ACTIVE_KID=k1
JWT_KEYS=k1:change-this-to-a-very-long-random-secret-at-least-32-characters
LOGIN_SOFT_LOCK_THRESHOLD=5
LOGIN_HARD_LOCK_THRESHOLD=10
LOGIN_SOFT_LOCK_SECONDS=900
LOGIN_HARD_LOCK_SECONDS=86400
POSTGRES_USER=mindvault
POSTGRES_PASSWORD=mindvault
POSTGRES_DB=mindvault
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_EMAIL_QUEUE=default
CELERY_TIMEZONE=UTC

# SMTP (set SMTP_ENABLED=true to send real invitation emails)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=MindVault AI
FRONTEND_BASE_URL=http://localhost:5173

# Documents / ingestion
DOCUMENT_STORAGE_DIR=/app/var/storage
DOCUMENT_MAX_SIZE_BYTES=26214400
DOCUMENT_CHUNK_SIZE_CHARS=1500
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_ALLOWED_SOURCE_TYPES=text,markdown,txt,md,text/plain,text/markdown,pdf,application/pdf,docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document