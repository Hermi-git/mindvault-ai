ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://mindvault:mindvault@postgres:5432/mindvault
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ISSUER=mindvault-ai
JWT_AUDIENCE=mindvault-clients
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
MFA_ATTEMPT_TTL_SECONDS=300
INVITATION_TTL_SECONDS=172800
JWT_ACTIVE_KID=k1
JWT_KEYS=k1:change-this-to-a-very-long-random-secret-at-least-32-characters
LOGIN_SOFT_LOCK_THRESHOLD=5
LOGIN_HARD_LOCK_THRESHOLD=10
LOGIN_SOFT_LOCK_SECONDS=900
LOGIN_HARD_LOCK_SECONDS=86400
POSTGRES_USER=mindvault
POSTGRES_PASSWORD=mindvault
POSTGRES_DB=mindvault
REDIS_URL=redis://redis:6379/0